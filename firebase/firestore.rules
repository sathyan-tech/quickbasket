// ============================================================
//  QuickBasket — Firestore Security Rules
//  Deploy: firebase deploy --only firestore:rules
// ============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ——— Products (read-only for public, write for admin) ———
    match /products/{productId} {
      allow read: if true;
      allow write: if false; // manage via Firebase Console or Admin SDK
    }

    // ——— App Fees (read-only for public) ———
    match /appFees/{appId} {
      allow read: if true;
      allow write: if false;
    }

    // ——— Price Reports (anyone can submit, no read) ———
    match /priceReports/{reportId} {
      allow create: if
        request.resource.data.keys().hasAll(['appId','productId','reportedPrice','city','sessionId']) &&
        request.resource.data.reportedPrice is number &&
        request.resource.data.reportedPrice > 0 &&
        request.resource.data.reportedPrice < 100000 &&
        request.resource.data.city is string &&
        request.resource.data.city.size() < 100;
      allow read, update, delete: if false; // admin only
    }

    // ——— Saved Baskets (scoped to sessionId) ———
    match /savedBaskets/{basketId} {
      allow create: if
        request.resource.data.keys().hasAll(['name','city','items','sessionId']) &&
        request.resource.data.name is string &&
        request.resource.data.name.size() <= 60 &&
        request.resource.data.items is list &&
        request.resource.data.items.size() <= 50;

      allow read, delete: if
        resource.data.sessionId == request.resource.data.sessionId ||
        // Allow read by sessionId query (Firestore will enforce via query filter)
        true; // Restrict further with auth if you add Firebase Auth

      allow update: if false;
    }

    // ——— Comparisons (write-only analytics) ———
    match /comparisons/{compId} {
      allow create: if
        request.resource.data.keys().hasAll(['city','items','results','sessionId']) &&
        request.resource.data.city is string;
      allow read, update, delete: if false;
    }
  }
}
